# ═══════════════════════════════════════════════════════════════
# KRONOS SUPER-APP — Variables de Entorno
# Copia este archivo como .env y rellena tus valores reales.
# Ver ENV_SETUP_GUIDE.md para instrucciones detalladas por servicio.
# ═══════════════════════════════════════════════════════════════

# ─── Servidor ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
SERVER_URL=http://localhost:5000

# ─── Cliente / Frontend ─────────────────────────────────────────
CLIENT_URL=http://localhost:3000
REACT_APP_API_URL=http://localhost:5000/api

# ─── Base de Datos ──────────────────────────────────────────────
# MongoDB Atlas (gratis): https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb+srv://usuario:contrasena@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ─── Autenticacion JWT ──────────────────────────────────────────
# Generar con: node -e "require('crypto').randomBytes(64).toString('base64')|{console.log}"
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRE=7d

# ─── Stripe (Pagos) ─────────────────────────────────────────────
# Obtener en: https://dashboard.stripe.com/apikeys
# Usar claves de MODO TEST (pk_test_ / sk_test_) para desarrollo
# BLOQUEANTE para funciones de pago
STRIPE_PUBLIC_KEY=pk_test_tu_clave_publica
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta
STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret
# Para el frontend React:
REACT_APP_STRIPE_PUBLIC_KEY=pk_test_tu_clave_publica

# ─── Suscripciones: 3 productos independientes (Stripe) ─────────
# Cada producto es independiente; el usuario paga el que quiera.
# Crear en Stripe Dashboard > Products y pegar el price_id (price_XXXX) de cada plan de pago.
# (Los planes "Gratuito" NO se registran: son la cuenta por defecto.)
#
# Webhook: Stripe Dashboard > Developers > Webhooks
#   URL:     https://tu-dominio.com/api/subscription/webhook
#   Eventos: checkout.session.completed, customer.subscription.updated,
#            customer.subscription.deleted, invoice.payment_failed
#   El secret va en STRIPE_WEBHOOK_SECRET (arriba).

# 🟦 Red Social
STRIPE_SOCIAL_PREMIUM_PRICE_ID=price_tu_price_id   # Premium $4.99

# 🟩 Generador de Scripts
STRIPE_SCRIPTS_ESTANDAR_PRICE_ID=price_tu_price_id # Estándar $4.99
STRIPE_SCRIPTS_PREMIUM_PRICE_ID=price_tu_price_id  # Premium $9.99
STRIPE_SCRIPTS_PRO_PRICE_ID=price_tu_price_id      # Pro $19.99

# 🟪 Generador de Videos e Imágenes
STRIPE_MEDIA_ESTANDAR_PRICE_ID=price_tu_price_id   # Estándar $9.99
STRIPE_MEDIA_PREMIUM_PRICE_ID=price_tu_price_id    # Premium $19.99
STRIPE_MEDIA_PRO_PRICE_ID=price_tu_price_id        # Pro $39.99

# Legacy (modelo viejo, ya no se usa con el nuevo catálogo):
# STRIPE_PRO_PRICE_ID=
# STRIPE_BUSINESS_PRICE_ID=

# ─── Cloudinary (Imagenes y Videos) ─────────────────────────────
# Gratis 25GB: https://cloudinary.com/console
# BLOQUEANTE para subida de media
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key_numerica
CLOUDINARY_API_SECRET=tu_api_secret

# ─── Email (Nodemailer) ──────────────────────────────────────────
# OPCIONAL — Sin configurar: emails no se envian (modo silencioso)
# Recomendado: Gmail con App Password (ver ENV_SETUP_GUIDE.md)
# App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=abcd efgh ijkl mnop
EMAIL_FROM=KRONOS <tu_email@gmail.com>

# ─── Redis (Cache) ───────────────────────────────────────────────
# OPCIONAL — Sin configurar: se usa cache en memoria (no persistente)
# Upstash gratis (10k req/dia): https://upstash.com/
REDIS_URL=rediss://default:tu_password@tu_host.upstash.io:6379

# ─── OpenAI (Funciones de IA) ────────────────────────────────────
# OPCIONAL — Sin configurar: features de AI deshabilitadas (no crashea)
# Obtener en: https://platform.openai.com/api-keys
# Nuevas cuentas reciben $5 de credito gratis
OPENAI_API_KEY=sk-proj-tu_openai_api_key

# ─── OpenWeatherMap (Clima para Delivery) ────────────────────────
# OPCIONAL — Sin configurar: se retornan datos mock de clima
# Gratis (1000 calls/dia): https://openweathermap.org/api
OPENWEATHER_API_KEY=tu_openweather_api_key

# ─── Google Maps (Mapas y Geocodificacion) ───────────────────────
# OPCIONAL — Alternativa gratuita: Nominatim/OpenStreetMap (sin key)
# Google Maps: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=tu_google_maps_api_key

# ─── Traduccion ──────────────────────────────────────────────────
# OPCIONAL — Sin ninguna configurada: retorna el texto original sin traducir

# Google Cloud Translate (pago con tier gratis):
# https://console.cloud.google.com/apis/library/translate.googleapis.com
GOOGLE_TRANSLATE_API_KEY=tu_google_translate_api_key

# DeepL Free (500k caracteres/mes): https://www.deepl.com/pro-api
# La clave free termina en :fx
DEEPL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx:fx

# Azure Cognitive Services Translator:
# https://portal.azure.com/#create/Microsoft.CognitiveServicesTextTranslation
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_KEY=tu_azure_translator_key

# ─── Web3 / Blockchain (Token KRO) ──────────────────────────────
# BLOQUEANTE para funciones de tokens KRO
# Infura gratis (100k req/dia): https://infura.io/
INFURA_API_KEY=tu_infura_api_key
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/tu_infura_api_key

# ADVERTENCIA: Usar SOLO una wallet de desarrollo, NUNCA una wallet con fondos reales
PRIVATE_KEY=0x_tu_clave_privada_de_wallet_de_desarrollo_SOLO

# Completar despues del deploy del contrato:
KRONOS_TOKEN_ADDRESS=0x_direccion_del_contrato_desplegado
KRONOS_NETWORK=sepolia

# ─── Token Economics ─────────────────────────────────────────────
ATTENTION_RATE=1
DAILY_REWARD_POOL=1000
STAKING_APY_30=5
STAKING_APY_60=10
STAKING_APY_90=15

# ─── Google OAuth 2.0 ────────────────────────────────────────────
# REQUERIDO para login con Google. Sin esto el boton de Google no funciona.
# INSTALAR PRIMERO: cd server && npm install passport passport-google-oauth20 passport-facebook
#
# Pasos para obtener las credenciales:
#   1. Ir a https://console.cloud.google.com/
#   2. Crear proyecto > APIs & Services > Credentials > Create Credentials > OAuth 2.0 Client IDs
#   3. Tipo de aplicacion: Web application
#   4. Agregar en "Authorized redirect URIs":
#      - Desarrollo: http://localhost:5000/api/auth/google/callback
#      - Produccion:  https://tu-dominio.com/api/auth/google/callback
#   5. Copiar Client ID y Client Secret aqui
GOOGLE_CLIENT_ID=tu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# ─── Facebook OAuth ──────────────────────────────────────────────
# REQUERIDO para login con Facebook. Sin esto el boton de Facebook no funciona.
#
# Pasos para obtener las credenciales:
#   1. Ir a https://developers.facebook.com/apps/
#   2. Crear App > tipo Consumer
#   3. Agregar producto "Facebook Login" desde el dashboard
#   4. Facebook Login > Settings > Valid OAuth Redirect URIs:
#      - Desarrollo: http://localhost:5000/api/auth/facebook/callback
#      - Produccion:  https://tu-dominio.com/api/auth/facebook/callback
#   5. Settings > Basic: copiar App ID y App Secret
FACEBOOK_APP_ID=tu_facebook_app_id
FACEBOOK_APP_SECRET=tu_facebook_app_secret
